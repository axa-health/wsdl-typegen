{
  "name": "@axah/wsdl-typegen",
  "version": "3.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/axa-health/wsdl-typegen.git"
  },
  "bugs": {
    "url": "https://github.com/axa-health/wsdl-typegen/issues"
  },
  "homepage": "https://github.com/axa-health/wsdl-typegen#readme",
  "bin": {
    "wsdl-typegen": "dist/index.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "tsx src/index.ts -- generate -t 'test/**/*.wsdl'",
    "build": "pnpm build:lib",
    "build:lib": "pnpm clean && tsc --build tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build",
    "test-typescript": "tsx src/index.ts generate 'test/**/*.wsdl' && tsc -p tsconfig.test.json",
    "release": "pnpm build && pnpm changeset publish",
    "fix": "biome check --fix --unsafe"
  },
  "dependencies": {
    "@biomejs/js-api": "6.0.0",
    "@biomejs/wasm-nodejs": "2.5.0",
    "@xmldom/xmldom": "^0.9.10",
    "commander": "15.0.0",
    "glob": "13.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@changesets/cli": "2.31.0",
    "@tsconfig/node22": "^22.0.5",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "24.13.2",
    "soap": "1.9.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.9.0"
}
