{
  "name": "@axah/wsdl-typegen",
  "version": "2.1.2",
  "main": "dist/index.js",
  "license": "MIT",
  "bin": "dist/index.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "npm-run-all -p dev:*",
    "dev:run": "nodemon --watch src -e ts --exec pnpm generate",
    "generate": "node-dev src/index.ts -- generate -t 'test/**/*.wsdl'",
    "build": "npm-run-all build:clean build:lib",
    "build:clean": "rimraf lib",
    "build:lib": "tsc --build tsconfig.build.json",
    "lint": "tsc --noEmit && eslint .",
    "prepublishOnly": "pnpm build",
    "test-typescript": "tsx src/index.ts generate 'test/**/*.wsdl' && tsc --noEmit",
    "release": "pnpm build && pnpm changeset publish",
    "fix": "biome check --fix --unsafe"
  },
  "dependencies": {
    "@biomejs/js-api": "6.0.0",
    "@biomejs/wasm-nodejs": "2.5.1",
    "@xmldom/xmldom": "^0.9.10",
    "commander": "15.0.0",
    "glob": "13.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@changesets/cli": "2.31.0",
    "@tsconfig/node22": "^22.0.5",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "24.13.2",
    "soap": "1.9.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.9.0"
}
