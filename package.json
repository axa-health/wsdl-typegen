{
  "name": "@axah/wsdl-typegen",
  "version": "2.1.2",
  "main": "dist/index.js",
  "license": "MIT",
  "bin": "dist/index.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "npm-run-all -p dev:*",
    "dev:run": "nodemon --watch src -e ts --exec pnpm generate",
    "generate": "node-dev src/index.ts -- generate -t 'test/**/*.wsdl'",
    "build": "npm-run-all build:clean build:lib",
    "build:clean": "rimraf lib",
    "build:lib": "tsc --build tsconfig.build.json",
    "lint": "tsc --noEmit && eslint .",
    "prepublishOnly": "pnpm build",
    "test-typescript": "tsx src/index.ts generate 'test/**/*.wsdl' && tsc --noEmit",
    "release": "pnpm build && pnpm changeset publish",
    "fix": "biome check --fix --unsafe"
  },
  "dependencies": {
    "@biomejs/js-api": "4.0.0",
    "@biomejs/wasm-nodejs": "2.4.6",
    "@xmldom/xmldom": "^0.8.11",
    "chokidar": "5.0.0",
    "commander": "14.0.3",
    "glob": "13.0.6",
    "xml2js": "0.6.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@changesets/cli": "2.30.0",
    "@tsconfig/node22": "^22.0.5",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "24.12.0",
    "@types/xml2js": "0.4.14",
    "soap": "1.8.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.32.1"
}
